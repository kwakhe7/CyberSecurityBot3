<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>


  <!-- Ensure the splash PNG is copied to the output folder so runtime loader can find it. The ItemGroup is conditioned so build won't fail if the file is absent during development. -->
  <ItemGroup Condition="Exists('Assets\logo_png')">
    <Content Include="Assets\logo_png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
