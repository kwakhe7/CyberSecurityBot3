<Window x:Class="ChatbotPart2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatbotPart2"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="900">
    <Grid Background="#5A5A5A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Header with bot name and mode buttons -->
        <Border Grid.Row="0" Background="#4D4D4D" Padding="12" CornerRadius="6" Margin="8">
            <StackPanel>
                <DockPanel>
                    <TextBlock Text="CyberBot" FontSize="20" FontWeight="Bold" Foreground="White" DockPanel.Dock="Left" />
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Button x:Name="ChatModeButton" Content="Chat" Width="80" Margin="4,0" Click="ChatModeButton_Click"/>
                        <Button x:Name="QuizModeButton" Content="Quiz" Width="80" Margin="4,0" Click="QuizModeButton_Click"/>
                        <Button x:Name="TasksModeButton" Content="Tasks" Width="80" Margin="4,0" Click="TasksModeButton_Click"/>
                        <!-- Activity log button styled to fit the header -->
                        <Button x:Name="ActivityLoggerButton" Content="Activity Log" Width="120" Margin="8,0,0,0" Click="ActivityLoggerButton_Click"
                                Background="#1E90FF" Foreground="White" FontWeight="Bold"/>
                        <Button x:Name="TasksJsonButton" Content="Tasks JSON" Width="110" Margin="8,0,0,0" Click="TasksJsonButton_Click"
                                Background="#00C853" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </DockPanel>

                <TextBlock FontFamily="Consolas" Foreground="White" FontSize="12" TextWrapping="Wrap" xml:space="preserve" Margin="0,8,0,0">
                    <Run>
                        <![CDATA[
   ███████╗ █████╗ ███████╗███████╗███╗   ██╗███████╗████████╗
   ██╔════╝██╔══██╗██╔════╝██╔════╝████╗  ██║██╔════╝╚══██╔══╝
   ███████╗███████║█████╗  █████╗  ██╔██╗ ██║█████╗     ██║   
   ╚════██║██╔══██║██╔══╝  ██╔══╝  ██║╚██╗██║██╔══╝     ██║   
   ███████║██║  ██║██║     ███████╗██║ ╚████║███████╗   ██║   
   ╚══════╝╚═╝  ╚═╝╚═╝     ╚══════╝╚═╝  ╚═══╝╚══════╝   ╚═╝   
        
          ╔══════════════════════════════════════════╗
          ║     S A F E N E T   A S S I S T A N T    ║
          ║      Your Cybersecurity Guide & Buddy    ║
          ╚══════════════════════════════════════════╝
                        ]]>
                    </Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Row 1: Content area - Chat panel, Quiz view and Task view (switch visibility) -->
        <Grid Grid.Row="1" x:Name="MainContent" Margin="8">
            <!-- Chat panel (default visible) -->
            <Border x:Name="ChatBorder" Background="#404040" Padding="8" CornerRadius="6" Visibility="Visible">
                <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ChatTextBlock" Foreground="White" TextWrapping="Wrap" FontFamily="Consolas" FontSize="13" />
                </ScrollViewer>
            </Border>

            <!-- Quiz view (initially collapsed) -->
            <local:QuizView x:Name="QuizViewControl" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- Task view (initially collapsed) -->
            <local:TaskView x:Name="TaskViewControl" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Grid>

        <!-- Row 2: Input row with TextBox and Send Button (hidden for Quiz/Tasks) -->
        <Border x:Name="InputBorder" Grid.Row="2" Background="#021826" Padding="8" Margin="8" CornerRadius="6" Visibility="Visible">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputTextBox" Grid.Column="0" Height="34" Margin="0,0,8,0"
                         Background="#4D4D4D" Foreground="White" BorderBrush="White" CaretBrush="White"
                         VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="13"
                         KeyDown="InputTextBox_KeyDown" />

                <Button x:Name="SendButton" Grid.Column="1" Width="90" Height="34" Content="Send"
                        Background="White" Foreground="#5A5A5A" FontWeight="Bold" Click="SendButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
