<Window x:Class="ChatbotPart2.TaskJsonViewer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tasks JSON Viewer" Height="520" Width="760" WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" Background="#252526" Foreground="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Tasks JSON" FontSize="18" FontWeight="Bold" Margin="6" />

        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="6" Padding="8" Margin="0,8,0,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="JsonTextBox" Background="#1E1E1E" BorderThickness="0" Foreground="White"
                         FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"
                         IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="RefreshButton" Content="Refresh" Width="90" Margin="0,6,8,0" Click="RefreshButton_Click"/>
            <Button x:Name="OpenFolderButton" Content="Open Folder" Width="100" Margin="0,6,8,0" Click="OpenFolderButton_Click"/>
            <Button x:Name="CloseButton" Content="Close" Width="90" Margin="0,6,0,0" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
