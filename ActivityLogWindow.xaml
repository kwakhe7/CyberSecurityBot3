<Window x:Class="ChatbotPart2.ActivityLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activity Log" Height="480" Width="640" WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" Background="#252526" Foreground="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Activity Log" FontSize="18" FontWeight="Bold" Margin="6" />

        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="6" Padding="8" Margin="0,8,0,8">
            <ListBox x:Name="ActivityListBox" Background="#1E1E1E" BorderThickness="0" Foreground="White"
                     FontFamily="Consolas" FontSize="13" HorizontalContentAlignment="Left" />
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CopyButton" Content="Copy" Width="90" Margin="0,6,8,0" Click="CopyButton_Click"/>
            <Button x:Name="ClearButton" Content="Clear" Width="90" Margin="0,6,8,0" Click="ClearButton_Click"/>
            <Button x:Name="CloseButton" Content="Close" Width="90" Margin="0,6,0,0" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
