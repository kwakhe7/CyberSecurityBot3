<Window x:Class="ChatbotPart2.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Height="320" Width="480"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True">
    <Border Background="#FF1E1E1E" CornerRadius="12" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Use the vector AppLogo resource by default. If an external PNG
                 exists at runtime the code-behind will replace this image. -->
            <Grid Grid.Row="0">
                <Image x:Name="LogoImage" Source="{StaticResource AppLogo}" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Width="260" Height="200" RenderOptions.BitmapScalingMode="HighQuality" />
            </Grid>

            <!-- Bot name -->
            <StackPanel Grid.Row="1" Margin="0,12,0,0" HorizontalAlignment="Center">
                <TextBlock Text="SAFENET" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                <TextBlock Text="Your secure assistant" FontSize="12" Foreground="#FFBBBBBB" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</Window>